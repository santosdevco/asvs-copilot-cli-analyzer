# ── GitHub Copilot (default LLM provider) ────────────────────────────────────
# LLM settings
LLM_PROVIDER=claude                  # copilot (default) | openai | anthropic
# LLM_MODEL=gpt-4.1                     # gpt-4.1 | gpt-5-mini | claude-sonnet-4.6 | auto
LLM_MODEL=claude-sonnet-4.6                   # gpt-4.1 | gpt-5-mini | claude-sonnet-4.6 | auto
LLM_MAX_TOKENS=8192

CLAUDE_SETTINGS_PATH=.claude/settings1.json # 
CONTEXT_FORMAT=yml
ANALYSIS_OUTPUT_FORMAT=json