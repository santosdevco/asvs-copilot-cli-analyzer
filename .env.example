# ── GitHub Copilot (default LLM provider) ────────────────────────────────────
# LLM settings
LLM_PROVIDER=copilot                  # copilot (default) | openai | anthropic
# LLM_MODEL=gpt-4.1                     # gpt-4.1 | gpt-5-mini | claude-sonnet-4.6 | auto
LLM_MODEL=claude-sonnet-4.5                   # gpt-4.1 | gpt-5-mini | claude-sonnet-4.6 | auto
LLM_MAX_TOKENS=8192

# Proveedores alternativos (solo si cambias LLM_PROVIDER)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional extra -D arguments separated by spaces
# Example: SONAR_EXTRA_ARGS=-Dsonar.qualitygate.wait=true -Dsonar.verbose=true
SONAR_EXTRA_ARGS=



COPILOT_MODEL=claude-sonnet-4.5